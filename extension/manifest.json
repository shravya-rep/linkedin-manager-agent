{
  "manifest_version": 3,
  "name": "LinkLens",
  "version": "1.0.0",
  "description": "Watch LinkedIn through your own lens. Signal in, noise out.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/feed/*",
        "https://www.linkedin.com/",
        "http://localhost/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:* http://127.0.0.1:*;"
  },
  "web_accessible_resources": [
    {
      "resources": ["digest.html", "digest.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkLens"
  }
}
